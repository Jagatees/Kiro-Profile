{
  "name": "kiro-stat",
  "displayName": "Kiro Stat",
  "description": "Local Kiro stats for tokens, sessions, models, activity, and optional public leaderboard sharing.",
  "version": "0.3.0",
  "publisher": "jagatees",
  "license": "MIT",
  "homepage": "https://github.com/jagatees/kiro-profile#readme",
  "bugs": {
    "url": "https://github.com/jagatees/kiro-profile/issues"
  },
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagatees/kiro-profile.git"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "kiro",
    "developer stats",
    "productivity",
    "leaderboard",
    "activity"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:kiroStat.profile",
    "onCommand:kiroStat.openProfile",
    "onCommand:kiroStat.refresh",
    "onCommand:kiroStat.syncLeaderboard",
    "onCommand:kiroStat.exportDiagnostics"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kiroStat.openProfile",
        "title": "Kiro Stat: Open Stats",
        "category": "Kiro Stat",
        "icon": "$(account)"
      },
      {
        "command": "kiroStat.refresh",
        "title": "Kiro Stat: Refresh Stats",
        "category": "Kiro Stat",
        "icon": "$(refresh)"
      },
      {
        "command": "kiroStat.syncLeaderboard",
        "title": "Kiro Stat: Sync Leaderboard Now",
        "category": "Kiro Stat"
      },
      {
        "command": "kiroStat.exportDiagnostics",
        "title": "Kiro Stat: Export Diagnostics",
        "category": "Kiro Stat"
      },
      {
        "command": "kiroStat.openLogs",
        "title": "Kiro Stat: Open Output Logs",
        "category": "Kiro Stat"
      },
      {
        "command": "kiroStat.openSettings",
        "title": "Kiro Stat: Open Settings",
        "category": "Kiro Stat"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kiroStat",
          "title": "Kiro Stat",
          "icon": "resources/activity.svg"
        }
      ]
    },
    "views": {
      "kiroStat": [
        {
          "id": "kiroStat.profile",
          "name": "Profile",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Kiro Stat",
      "properties": {
        "kiroStat.displayName": {
          "type": "string",
          "default": "Kiro Developer",
          "description": "Fallback display name shown when Kiro does not expose a local account display name."
        },
        "kiroStat.username": {
          "type": "string",
          "default": "kiro-builder",
          "description": "Fallback handle used when no local Kiro account label is available."
        },
        "kiroStat.planLabel": {
          "type": "string",
          "default": "Local",
          "description": "Small account label shown beside the username."
        },
        "kiroStat.leaderboardUrl": {
          "type": "string",
          "default": "https://kiro-profile-leaderboard-brown.vercel.app",
          "description": "HTTPS leaderboard URL. Plain HTTP is accepted only for localhost development."
        },
        "kiroStat.maxScanFiles": {
          "type": "number",
          "default": 2000,
          "minimum": 100,
          "maximum": 10000,
          "description": "Maximum files scanned from each local Kiro data source."
        },
        "kiroStat.diagnosticLogging": {
          "type": "boolean",
          "default": false,
          "description": "Write detailed, redacted collection information to the Kiro Stat output channel."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "kiroStat.refresh",
          "when": "view == kiroStat.profile",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "kiroStat.openProfile"
        },
        {
          "command": "kiroStat.refresh"
        },
        {
          "command": "kiroStat.syncLeaderboard"
        },
        {
          "command": "kiroStat.exportDiagnostics"
        },
        {
          "command": "kiroStat.openLogs"
        },
        {
          "command": "kiroStat.openSettings"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc --noEmit -p ./",
    "lint": "eslint src test --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --allow-missing-repository",
    "validate": "npm run format:check && npm run check && npm run lint && npm run test && npm run package"
  },
  "devDependencies": {
    "@eslint/js": "9.32.0",
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.2.1",
    "eslint": "9.32.0",
    "prettier": "^3.8.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.38.0",
    "vitest": "3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
